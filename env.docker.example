# Copy to .env on the server: cp env.docker.example .env
# Set APP_KEY: docker compose run --rm --no-deps app php artisan key:generate --no-interaction
# (or: php artisan key:generate --show locally and paste the value)

APP_NAME=TIPTAP
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://sln.tiptapafrica.co.tz

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=salon
# Use MySQL root inside Docker (simplest). Set DB_PASSWORD identical to MYSQL_ROOT_PASSWORD.
DB_USERNAME=root
DB_PASSWORD=change_this_root_password

# phpMyAdmin: log in as root + this password (full access). Same value as DB_PASSWORD above.
MYSQL_ROOT_PASSWORD=change_this_root_password

BCRYPT_ROUNDS=12

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

SANCTUM_STATEFUL_DOMAINS=sln.tiptapafrica.co.tz

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@tiptapafrica.co.tz"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

FEEDBACK_VISIBLE_AFTER_MINUTES=60
